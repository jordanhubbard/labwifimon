            "type": "influxdb",
            "uid": "influxdb-labwifimon"
          },
          "query": "from(bucket: \"wifi_metrics\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"mqtt_consumer\")\n  |> filter(fn: (r) => r._field == \"wifi_rssi_dbm\")\n  |> group(columns: [\"topic\"])\n  |> last()\n  |> group()\n  |> count()",
