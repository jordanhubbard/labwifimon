# =============================================================================
# LabWiFiMon — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values, OR run setup.sh which
# generates this file automatically with a random token.
#
# DO NOT commit .env to version control — it contains secrets.
# =============================================================================

# InfluxDB 2 — admin API token (used by Telegraf and Grafana)
# Generate with: openssl rand -base64 32 | tr -d '/+=' | head -c 44
INFLUXDB_TOKEN=CHANGE_ME_GENERATE_WITH_SETUP_SH

# InfluxDB 2 — organization and bucket (defaults match project name)
INFLUXDB_ORG=labwifimon
INFLUXDB_BUCKET=wifi_metrics

# InfluxDB 2 — admin UI password (web UI at :8086)
INFLUXDB_ADMIN_PASSWORD=CHANGE_ME_MIN_8_CHARS

# Grafana — admin UI password (web UI at :3000, username: admin)
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME
